{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:8000/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
